# ---- Deployment ----
# Secrets below must also be set in Cloudflare Pages dashboard
# (Settings > Environment variables) or via `wrangler secret put VAR_NAME`

# Supabase (from `bunx supabase status` after `bunx supabase start`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Apple Wallet (requires Apple Developer Account)
NUXT_APPLE_PASS_TYPE_ID=
NUXT_APPLE_TEAM_ID=
NUXT_APPLE_WWDR_CERT=
NUXT_APPLE_SIGNER_CERT=
NUXT_APPLE_SIGNER_KEY=
NUXT_APPLE_SIGNER_KEY_PASSPHRASE=

# Google Wallet (requires Google Cloud project with Wallet API enabled)
NUXT_GOOGLE_WALLET_ISSUER_ID=
NUXT_GOOGLE_SERVICE_ACCOUNT_EMAIL=
NUXT_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Samsung Wallet (requires Samsung Partner Portal registration)
NUXT_SAMSUNG_PARTNER_ID=
NUXT_SAMSUNG_CARD_ID=
NUXT_SAMSUNG_PRIVATE_KEY=

# App
NUXT_PUBLIC_APP_URL=http://localhost:8989
NUXT_QR_TOKEN_SECRET=secret-yang-sangat-rahasia-sekali-banget
